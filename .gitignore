# Downloaded tooling — fetched by scripts/install-tools.ps1, not committed
tools/*
!tools/.gitkeep
!tools/README.md

# Large binaries are gitignored as a class. Specific firmware files we
# DO want to track (the small patch payloads and reference originals
# under firmware/patches and firmware/originals) are unignored below.
*.img
*.bin
*.raw

# firmware/ subdirectories:
#   patches/   — committed (scripts can't run without these)
#   originals/ — committed (used by restore-adb-auth, restore-boot, patch-parameter)
#   system-probes/ — gitignored (large partial /system dumps; regenerable)
#   scratch/       — gitignored (one-off probes, verification reads)
firmware/system-probes/
firmware/scratch/
!firmware/patches/*.img
!firmware/patches/*.bin
!firmware/originals/*.img
!firmware/originals/*.bin

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc

# session logs / scratch dumps
log/
dumps-tablet-reset/

# Old per-unit scratch dirs (unused; per-unit captures live in mabu-archive/)
backups/
backups-test/

# Legacy dumps/ location (migrated to firmware/) — keep gitignored in case
# any local working trees still have it
dumps/

# Large APKs we don't ship in the repo (downloadable from F-Droid)
apks/Termux.apk
apks/Termux-API.apk
